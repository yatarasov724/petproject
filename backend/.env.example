# ── Required ──────────────────────────────────────────────────────────────────
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Channel/group ID. To find it:
#   1. Add @userinfobot to your channel
#   2. Forward any message there — it replies with the chat ID
# Public channel: @mychannel  |  Private channel/group: -1001234567890
TELEGRAM_CHANNEL_ID=-1001234567890

# ── Optional (safe defaults shown) ───────────────────────────────────────────
# SQLite file path.
#   Local:  sqlite:///./moex_assistant.db   (relative to backend/)
#   Docker: sqlite:////data/moex_assistant.db  (absolute, matches volume mount)
DATABASE_URL=sqlite:///./moex_assistant.db

# CORS origin (only matters if you add a frontend)
FRONTEND_URL=http://localhost:3000

# Logging: "text" for local dev, "json" for Docker / log aggregators
LOG_FORMAT=text
LOG_LEVEL=INFO

# DRY_RUN=true — full pipeline runs, but Telegram HTTP calls are skipped.
# Messages are logged to stdout instead. Use this to verify the pipeline
# without sending to the real channel.
# DRY_RUN=false
